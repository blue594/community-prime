<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.community.prime.mapper.ServiceBookingMapper">

    <resultMap id="BaseResultMap" type="com.community.prime.entity.ServiceBooking">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="service_type_id" property="serviceTypeId"/>
        <result column="service_name" property="serviceName"/>
        <result column="price" property="price"/>
        <result column="booking_date" property="bookingDate"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="address" property="address"/>
        <result column="phone" property="phone"/>
        <result column="remark" property="remark"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 查询某时间段是否已被预约 -->
    <select id="countConflictBooking" resultType="int">
        SELECT COUNT(*) FROM tb_service_booking
        WHERE service_type_id = #{serviceTypeId}
        AND booking_date = #{bookingDate}
        AND status NOT IN (4)
        AND (
            (start_time &lt;= #{startTime} AND end_time &gt; #{startTime})
            OR (start_time &lt; #{endTime} AND end_time &gt;= #{endTime})
            OR (start_time &gt;= #{startTime} AND end_time &lt;= #{endTime})
        )
    </select>

    <!-- 查询用户的预约列表 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM tb_service_booking
        WHERE user_id = #{userId}
        <if test="status != null">
            AND status = #{status}
        </if>
        AND deleted = 0
        ORDER BY create_time DESC
    </select>

</mapper>
