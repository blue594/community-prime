<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.community.prime.mapper.ProductOrderMapper">

    <resultMap id="BaseResultMap" type="com.community.prime.entity.ProductOrder">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="product_id" property="productId"/>
        <result column="quantity" property="quantity"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="pay_amount" property="payAmount"/>
        <result column="address" property="address"/>
        <result column="phone" property="phone"/>
        <result column="status" property="status"/>
        <result column="pay_type" property="payType"/>
        <result column="create_time" property="createTime"/>
        <result column="pay_time" property="payTime"/>
        <result column="delivery_time" property="deliveryTime"/>
        <result column="finish_time" property="finishTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectOrderPage" resultMap="BaseResultMap">
        SELECT id, user_id, product_id, quantity, total_amount, pay_amount,
        status, pay_type, create_time, pay_time
        FROM tb_product_order
        WHERE user_id = #{userId}
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

    <select id="selectOrderPageBad" resultMap="BaseResultMap">
        SELECT * FROM tb_product_order
        WHERE user_id = #{userId}
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>